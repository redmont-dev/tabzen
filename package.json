{
  "name": "tabzen",
  "private": true,
  "scripts": {
    "dev:ext": "pnpm --filter @tabzen/extension dev",
    "build:ext": "pnpm --filter @tabzen/extension build",
    "test:ext": "pnpm --filter @tabzen/extension test",
    "dev:site": "pnpm --filter @tabzen/site dev",
    "build:site": "pnpm --filter @tabzen/site build",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @tabzen/extension test:e2e",
    "lint": "pnpm -r lint"
  }
}
